{
  "name": "johnston-family-dashboard-api",
  "version": "0.1.0",
  "description": "Azure Functions backend for the Johnston Family Dashboard.",
  "private": true,
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.0",
    "@azure/functions": "^4.5.1",
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^4.5.0",
    "jose": "^5.9.6",
    "node-ical": "^0.20.1",
    "tsdav": "^2.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
